{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Amsterdam)",
    "local>ErasmusAndre/erasmus.works//.renovate/autoMerge.json",
    "local>ErasmusAndre/erasmus.works//.renovate/groups.json",
    "local>ErasmusAndre/erasmus.works//.renovate/overrides.json"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "rangeStrategy": "pin",
  "enabledManagers": [
    "argocd",
    "custom.regex",
    "github-actions",
    "helm-values",
    "kubernetes"
  ],
  "argocd": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+/application\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track Talos image references outside Kubernetes manifests",
      "managerFilePatterns": [
        "/(^|/)talos/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>ghcr\\.io\\/siderolabs\\/kubelet):(?<currentValue>[^\\s#]+)",
        "image:\\s+(?<depName>factory\\.talos\\.dev\\/installer\\/[^:]+):(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track Helm chart versions for split chart apps under argocd-apps",
      "managerFilePatterns": [
        "/(^|/)kubernetes/clusters/homelab/argocd-apps/.+/chart/application\\.ya?ml$/"
      ],
      "matchStrings": [
        "repoURL:\\s+(?<registryUrl>https:\\/\\/[^\\s]+)\\s+chart:\\s+(?<depName>[^\\s]+)\\s+targetRevision:\\s+(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Track app image repository and tag pairs in app Helm values",
      "managerFilePatterns": [
        "/(^|/)kubernetes/apps/.+/values\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+repository:\\s+(?<depName>[^\\s#]+)\\s+tag:\\s+(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/(^|/)\\.github/workflows/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+/values\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  }
}
